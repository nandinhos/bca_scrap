# Credenciais do Banco de Dados
DB_HOST=mariadb
DB_USER=bca_user
DB_PASS=
DB_NAME=bca_db

# Configurações SMTP
SMTP_HOST=smtp.fab.mil.br
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Sistema BCA GAC-PAC

# Configurações da Aplicação
BASE_URL=http://localhost:8092
APP_ENV=production

# Autenticacao API (desabilitado por padrao)
API_TOKEN_REQUIRED=false
API_TOKEN=changeme_token_seguro_aqui

# Rate Limiting (habilitado por padrao)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

